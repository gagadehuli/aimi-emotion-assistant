# 后端代理配置。复制为 server/.env 后再填。 server/.env 已在 .gitignore，不会进入 Git。

# Google AI Studio 申请的免费 key：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# 模型可随时调整。默认 gemini-2.5-flash；想换 pro / preview 直接改这里，代码不动。
GEMINI_MODEL=gemini-2.5-flash

# 监听端口
PORT=8787

# 允许的前端来源。开发期 * 即可；生产环境收紧成具体 origin。
ALLOWED_ORIGINS=*
